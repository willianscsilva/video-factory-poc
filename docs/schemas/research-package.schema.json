{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "research-package.schema.json",
  "title": "ResearchPackage",
  "description": "Contrato mínimo v0.1.0 para o pacote produzido pelo Agente de Pesquisa.",
  "type": "object",
  "required": [
    "schema_version",
    "package_id",
    "created_at",
    "input_origin",
    "topic",
    "summary",
    "sources",
    "claims"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v0.1.0"
    },
    "package_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "input_origin": {
      "type": "string",
      "minLength": 1
    },
    "topic": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "source_id",
          "title",
          "accessed_at"
        ],
        "properties": {
          "source_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "publisher": {
            "type": "string",
            "minLength": 1
          },
          "accessed_at": {
            "type": "string",
            "format": "date"
          }
        }
      }
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "claim_id",
          "text",
          "classification"
        ],
        "properties": {
          "claim_id": {
            "type": "string",
            "minLength": 1
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "classification": {
            "type": "string",
            "enum": [
              "fact",
              "hypothesis",
              "opinion",
              "estimate"
            ]
          },
          "source_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "notes": {
            "type": "string",
            "minLength": 1
          }
        },
        "if": {
          "properties": {
            "classification": {
              "const": "fact"
            }
          }
        },
        "then": {
          "required": [
            "source_ids"
          ]
        }
      }
    },
    "source_conflicts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "conflict_id",
          "description",
          "source_ids"
        ],
        "properties": {
          "conflict_id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "source_ids": {
            "type": "array",
            "minItems": 2,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "impact": {
            "type": "string",
            "minLength": 1
          },
          "notes": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "open_questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
